<?xml version="1.0"?>
<robot name="robotanik">
  <link name="base_footprint"/>

  <joint name="base_footprint_joint" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link"/>
    <origin xyz="0 0 0.215" rpy="0 0 0"/>
    <!-- 0.065→0.215: zemin + tekerlek yarıçapı(0.065) + gövde yarısı(0.15) -->
  </joint>

  <link name="base_link">
    <visual>
      <geometry>
        <box size="0.50 0.35 0.30"/>
      </geometry>
      <material name="green">
        <color rgba="0.0 0.8 0.0 1.0"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <box size="0.50 0.35 0.30"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="15.0"/>
      <inertia ixx="0.284" ixy="0" ixz="0"
               iyy="0.542" iyz="0"
               izz="0.638"/>
    </inertial>
  </link>
  <gazebo reference="base_link">
    <material>Gazebo/Green</material>
  </gazebo>

  <!-- ===== ARKA SOL TEKERLEK (TAHRİKLİ) ===== -->
  <link name="rear_left_wheel">
    <visual>
      <geometry>
        <cylinder radius="0.065" length="0.058"/>
      </geometry>
      <material name="black">
        <color rgba="0.1 0.1 0.1 1.0"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.065" length="0.058"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.5"/>
      <inertia ixx="0.001" ixy="0" ixz="0"
               iyy="0.001" iyz="0"
               izz="0.001"/>
    </inertial>
  </link>
  <gazebo reference="rear_left_wheel">
    <material>Gazebo/Black</material>
    <mu1>1.5</mu1>
    <mu2>1.5</mu2>
  </gazebo>

  <joint name="rear_left_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="rear_left_wheel"/>
    <origin xyz="-0.15 0.204 -0.15" rpy="-1.5708 0 0"/>
    <!-- z=-0.15: gövde merkezinden tam tabana, tekerlek zeminde -->
    <axis xyz="0 0 1"/>
  </joint>

  <!-- ===== ARKA SAĞ TEKERLEK (TAHRİKLİ) ===== -->
  <link name="rear_right_wheel">
    <visual>
      <geometry>
        <cylinder radius="0.065" length="0.058"/>
      </geometry>
      <material name="black">
        <color rgba="0.1 0.1 0.1 1.0"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.065" length="0.058"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.5"/>
      <inertia ixx="0.001" ixy="0" ixz="0"
               iyy="0.001" iyz="0"
               izz="0.001"/>
    </inertial>
  </link>
  <gazebo reference="rear_right_wheel">
    <material>Gazebo/Black</material>
    <mu1>1.5</mu1>
    <mu2>1.5</mu2>
  </gazebo>

  <joint name="rear_right_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="rear_right_wheel"/>
    <origin xyz="-0.15 -0.204 -0.15" rpy="1.5708 0 0"/>
    <!-- z=-0.15: gövde merkezinden tam tabana -->
    <axis xyz="0 0 -1"/>
  </joint>

  <!-- ===== ÖN SOL SARHOŞ TEKERLEK ===== -->
  <link name="front_left_caster">
    <visual>
      <geometry>
        <cylinder radius="0.065" length="0.058"/>
      </geometry>
      <material name="gray">
        <color rgba="0.6 0.6 0.6 1.0"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.065" length="0.058"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.3"/>
      <inertia ixx="0.0005" ixy="0" ixz="0"
               iyy="0.0005" iyz="0"
               izz="0.0005"/>
    </inertial>
  </link>
  <gazebo reference="front_left_caster">
    <material>Gazebo/Grey</material>
    <mu1>0.0</mu1>
    <mu2>0.0</mu2>
  </gazebo>

  <joint name="front_left_caster_joint" type="fixed">
    <parent link="base_link"/>
    <child link="front_left_caster"/>
    <origin xyz="0.15 0.204 -0.15" rpy="-1.5708 0 0"/>
    <!-- z=-0.15: arka tekerleklerle aynı seviye -->
  </joint>

  <!-- ===== ÖN SAĞ SARHOŞ TEKERLEK ===== -->
  <link name="front_right_caster">
    <visual>
      <geometry>
        <cylinder radius="0.065" length="0.058"/>
      </geometry>
      <material name="gray">
        <color rgba="0.6 0.6 0.6 1.0"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.065" length="0.058"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.3"/>
      <inertia ixx="0.0005" ixy="0" ixz="0"
               iyy="0.0005" iyz="0"
               izz="0.0005"/>
    </inertial>
  </link>
  <gazebo reference="front_right_caster">
    <material>Gazebo/Grey</material>
    <mu1>0.0</mu1>
    <mu2>0.0</mu2>
  </gazebo>

  <joint name="front_right_caster_joint" type="fixed">
    <parent link="base_link"/>
    <child link="front_right_caster"/>
    <origin xyz="0.15 -0.204 -0.15" rpy="1.5708 0 0"/>
  </joint>

  <!-- ===== SONAR SENSÖRLER ===== -->
  <link name="sonar_front_center">
    <visual>
      <geometry><box size="0.02 0.04 0.02"/></geometry>
      <material name="blue"><color rgba="0 0 1 1"/></material>
    </visual>
  </link>
  <joint name="sonar_front_center_joint" type="fixed">
    <parent link="base_link"/>
    <child link="sonar_front_center"/>
    <origin xyz="0.26 0 0.05" rpy="0 0 0"/>
  </joint>
  <gazebo reference="sonar_front_center">
    <material>Gazebo/Blue</material>
    <sensor type="ray" name="sonar_front_center_sensor">
      <pose>0 0 0 0 0 0</pose>
      <visualize>true</visualize>
      <update_rate>10</update_rate>
      <ray>
        <scan>
          <horizontal>
            <samples>5</samples><resolution>1</resolution>
            <min_angle>-0.26</min_angle><max_angle>0.26</max_angle>
          </horizontal>
        </scan>
        <range><min>0.02</min><max>4.0</max><resolution>0.01</resolution></range>
      </ray>
      <plugin name="gazebo_ros_range_fc" filename="libgazebo_ros_ray_sensor.so">
        <ros><remapping>~/out:=sonar/front_center</remapping></ros>
        <output_type>sensor_msgs/Range</output_type>
        <radiation_type>ultrasound</radiation_type>
        <frame_name>sonar_front_center</frame_name>
      </plugin>
    </sensor>
  </gazebo>

  <link name="sonar_front_left">
    <visual>
      <geometry><box size="0.02 0.04 0.02"/></geometry>
      <material name="blue"><color rgba="0 0 1 1"/></material>
    </visual>
  </link>
  <joint name="sonar_front_left_joint" type="fixed">
    <parent link="base_link"/>
    <child link="sonar_front_left"/>
    <origin xyz="0.20 0.175 0.05" rpy="0 0 0.785"/>
  </joint>
  <gazebo reference="sonar_front_left">
    <material>Gazebo/Blue</material>
    <sensor type="ray" name="sonar_front_left_sensor">
      <pose>0 0 0 0 0 0</pose>
      <visualize>true</visualize>
      <update_rate>10</update_rate>
      <ray>
        <scan>
          <horizontal>
            <samples>5</samples><resolution>1</resolution>
            <min_angle>-0.26</min_angle><max_angle>0.26</max_angle>
          </horizontal>
        </scan>
        <range><min>0.02</min><max>4.0</max><resolution>0.01</resolution></range>
      </ray>
      <plugin name="gazebo_ros_range_fl" filename="libgazebo_ros_ray_sensor.so">
        <ros><remapping>~/out:=sonar/front_left</remapping></ros>
        <output_type>sensor_msgs/Range</output_type>
        <radiation_type>ultrasound</radiation_type>
        <frame_name>sonar_front_left</frame_name>
      </plugin>
    </sensor>
  </gazebo>

  <link name="sonar_front_right">
    <visual>
      <geometry><box size="0.02 0.04 0.02"/></geometry>
      <material name="blue"><color rgba="0 0 1 1"/></material>
    </visual>
  </link>
  <joint name="sonar_front_right_joint" type="fixed">
    <parent link="base_link"/>
    <child link="sonar_front_right"/>
    <origin xyz="0.20 -0.175 0.05" rpy="0 0 -0.785"/>
  </joint>
  <gazebo reference="sonar_front_right">
    <material>Gazebo/Blue</material>
    <sensor type="ray" name="sonar_front_right_sensor">
      <pose>0 0 0 0 0 0</pose>
      <visualize>true</visualize>
      <update_rate>10</update_rate>
      <ray>
        <scan>
          <horizontal>
            <samples>5</samples><resolution>1</resolution>
            <min_angle>-0.26</min_angle><max_angle>0.26</max_angle>
          </horizontal>
        </scan>
        <range><min>0.02</min><max>4.0</max><resolution>0.01</resolution></range>
      </ray>
      <plugin name="gazebo_ros_range_fr" filename="libgazebo_ros_ray_sensor.so">
        <ros><remapping>~/out:=sonar/front_right</remapping></ros>
        <output_type>sensor_msgs/Range</output_type>
        <radiation_type>ultrasound</radiation_type>
        <frame_name>sonar_front_right</frame_name>
      </plugin>
    </sensor>
  </gazebo>

  <link name="sonar_back">
    <visual>
      <geometry><box size="0.02 0.04 0.02"/></geometry>
      <material name="blue"><color rgba="0 0 1 1"/></material>
    </visual>
  </link>
  <joint name="sonar_back_joint" type="fixed">
    <parent link="base_link"/>
    <child link="sonar_back"/>
    <origin xyz="-0.26 0 0.05" rpy="0 0 3.14159"/>
  </joint>
  <gazebo reference="sonar_back">
    <material>Gazebo/Blue</material>
    <sensor type="ray" name="sonar_back_sensor">
      <pose>0 0 0 0 0 0</pose>
      <visualize>true</visualize>
      <update_rate>10</update_rate>
      <ray>
        <scan>
          <horizontal>
            <samples>5</samples><resolution>1</resolution>
            <min_angle>-0.26</min_angle><max_angle>0.26</max_angle>
          </horizontal>
        </scan>
        <range><min>0.02</min><max>4.0</max><resolution>0.01</resolution></range>
      </ray>
      <plugin name="gazebo_ros_range_b" filename="libgazebo_ros_ray_sensor.so">
        <ros><remapping>~/out:=sonar/back</remapping></ros>
        <output_type>sensor_msgs/Range</output_type>
        <radiation_type>ultrasound</radiation_type>
        <frame_name>sonar_back</frame_name>
      </plugin>
    </sensor>
  </gazebo>

  <!-- ===== DIFF DRIVE PLUGIN ===== -->
  <gazebo>
    <plugin name="diff_drive" filename="libgazebo_ros_diff_drive.so">
      <update_rate>30</update_rate>
      <left_joint>rear_left_wheel_joint</left_joint>
      <right_joint>rear_right_wheel_joint</right_joint>
      <wheel_separation>0.408</wheel_separation>
      <wheel_diameter>0.130</wheel_diameter>
      <max_wheel_torque>20</max_wheel_torque>
      <max_wheel_acceleration>1.0</max_wheel_acceleration>
      <command_topic>cmd_vel</command_topic>
      <publish_odom>true</publish_odom>
      <publish_odom_tf>true</publish_odom_tf>
      <publish_wheel_tf>true</publish_wheel_tf>
      <odometry_topic>odom</odometry_topic>
      <odometry_frame>odom</odometry_frame>
      <robot_base_frame>base_footprint</robot_base_frame>
    </plugin>

    <plugin name="joint_state_publisher" filename="libgazebo_ros_joint_state_publisher.so">
      <update_rate>30</update_rate>
      <joint_name>rear_left_wheel_joint</joint_name>
      <joint_name>rear_right_wheel_joint</joint_name>
    </plugin>
  </gazebo>

</robot>
