<?xml version="1.0"?>
<robot name="robotanik">
<link name="base_footprint"/>

  <joint name="base_footprint_joint" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>
  
  <link name="base_link">
    <visual>
      <geometry>
        <box size="0.4 0.3 0.1"/> </geometry>
      <material name="green">
        <color rgba="0.0 0.8 0.0 1.0"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <box size="0.4 0.3 0.1"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="5.0"/> <inertia ixx="0.1" ixy="0" ixz="0" iyy="0.1" iyz="0" izz="0.1"/>
    </inertial>
  </link>

  <link name="right_wheel">
    <visual>
      <geometry>
        <cylinder radius="0.1" length="0.05"/>
      </geometry>
      <material name="black">
        <color rgba="0.0 0.0 0.0 1.0"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.1" length="0.05"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.5"/>
      <inertia ixx="0.01" ixy="0" ixz="0" iyy="0.01" iyz="0" izz="0.01"/>
    </inertial>
  </link>

  <joint name="right_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="right_wheel"/>
    <origin xyz="0.0 -0.175 0.0" rpy="1.5708 0 0"/> <axis xyz="0 0 -1"/> </joint>

  <link name="left_wheel">
    <visual>
      <geometry>
        <cylinder radius="0.1" length="0.05"/>
      </geometry>
      <material name="black">
        <color rgba="0.0 0.0 0.0 1.0"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.1" length="0.05"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.5"/>
      <inertia ixx="0.01" ixy="0" ixz="0" iyy="0.01" iyz="0" izz="0.01"/>
    </inertial>
  </link>

  <joint name="left_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="left_wheel"/>
    <origin xyz="0.0 0.175 0.0" rpy="-1.5708 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>

  <link name="caster_wheel">
    <visual>
      <geometry>
        <sphere radius="0.049"/>
      </geometry>
      <material name="white">
        <color rgba="1.0 1.0 1.0 1.0"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <sphere radius="0.049"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.2"/>
      <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/>
    </inertial>
  </link>

  <joint name="caster_joint" type="fixed">
    <parent link="base_link"/>
    <child link="caster_wheel"/>
    <origin xyz="0.15 0.0 -0.05" rpy="0 0 0"/> </joint>
    
  
  <link name="sonar_link">
    <visual>
      <geometry>
        <box size="0.02 0.05 0.02"/>
      </geometry>
      <material name="blue">
        <color rgba="0.0 0.0 1.0 1.0"/>
      </material>
    </visual>
  </link>

  <joint name="sonar_joint" type="fixed">
    <parent link="base_link"/>
    <child link="sonar_link"/>
    <origin xyz="0.2 0 0" rpy="0 0 0"/> </joint>

<link name="sonar_front_center">
    <visual>
      <geometry><box size="0.02 0.04 0.02"/></geometry>
      <material name="blue"><color rgba="0 0 1 1"/></material>
    </visual>
  </link>
  <joint name="sonar_front_center_joint" type="fixed">
    <parent link="base_link"/>
    <child link="sonar_front_center"/>
    <origin xyz="0.2 0 0" rpy="0 0 0"/> 
  </joint>
  <gazebo reference="sonar_front_center">
    <sensor type="ray" name="sonar_front_center_sensor">
      <pose>0 0 0 0 0 0</pose>
      <visualize>true</visualize>
      <update_rate>10</update_rate>
      <ray>
        <scan>
          <horizontal><samples>5</samples><resolution>1</resolution><min_angle>-0.26</min_angle><max_angle>0.26</max_angle></horizontal>
        </scan>
        <range><min>0.02</min><max>4.0</max><resolution>0.01</resolution></range>
      </ray>
      <plugin name="gazebo_ros_range_fc" filename="libgazebo_ros_ray_sensor.so">
        <ros><remapping>~/out:=sonar/front_center</remapping></ros>
        <output_type>sensor_msgs/Range</output_type>
        <radiation_type>ultrasound</radiation_type>
        <frame_name>sonar_front_center</frame_name>
      </plugin>
    </sensor>
  </gazebo>

  <link name="sonar_front_left">
    <visual>
      <geometry><box size="0.02 0.04 0.02"/></geometry>
      <material name="blue"><color rgba="0 0 1 1"/></material>
    </visual>
  </link>
  <joint name="sonar_front_left_joint" type="fixed">
    <parent link="base_link"/>
    <child link="sonar_front_left"/>
    <origin xyz="0.2 0.15 0" rpy="0 0 0.52"/> 
  </joint>
  <gazebo reference="sonar_front_left">
    <sensor type="ray" name="sonar_front_left_sensor">
      <pose>0 0 0 0 0 0</pose>
      <visualize>true</visualize>
      <update_rate>10</update_rate>
      <ray>
        <scan>
          <horizontal><samples>5</samples><resolution>1</resolution><min_angle>-0.26</min_angle><max_angle>0.26</max_angle></horizontal>
        </scan>
        <range><min>0.02</min><max>4.0</max><resolution>0.01</resolution></range>
      </ray>
      <plugin name="gazebo_ros_range_fl" filename="libgazebo_ros_ray_sensor.so">
        <ros><remapping>~/out:=sonar/front_left</remapping></ros>
        <output_type>sensor_msgs/Range</output_type>
        <radiation_type>ultrasound</radiation_type>
        <frame_name>sonar_front_left</frame_name>
      </plugin>
    </sensor>
  </gazebo>

  <link name="sonar_front_right">
    <visual>
      <geometry><box size="0.02 0.04 0.02"/></geometry>
      <material name="blue"><color rgba="0 0 1 1"/></material>
    </visual>
  </link>
  <joint name="sonar_front_right_joint" type="fixed">
    <parent link="base_link"/>
    <child link="sonar_front_right"/>
    <origin xyz="0.2 -0.15 0" rpy="0 0 -0.52"/> 
  </joint>
  <gazebo reference="sonar_front_right">
    <sensor type="ray" name="sonar_front_right_sensor">
      <pose>0 0 0 0 0 0</pose>
      <visualize>true</visualize>
      <update_rate>10</update_rate>
      <ray>
        <scan>
          <horizontal><samples>5</samples><resolution>1</resolution><min_angle>-0.26</min_angle><max_angle>0.26</max_angle></horizontal>
        </scan>
        <range><min>0.02</min><max>4.0</max><resolution>0.01</resolution></range>
      </ray>
      <plugin name="gazebo_ros_range_fr" filename="libgazebo_ros_ray_sensor.so">
        <ros><remapping>~/out:=sonar/front_right</remapping></ros>
        <output_type>sensor_msgs/Range</output_type>
        <radiation_type>ultrasound</radiation_type>
        <frame_name>sonar_front_right</frame_name>
      </plugin>
    </sensor>
  </gazebo>

  <link name="sonar_back">
    <visual>
      <geometry><box size="0.02 0.04 0.02"/></geometry>
      <material name="blue"><color rgba="0 0 1 1"/></material>
    </visual>
  </link>
  <joint name="sonar_back_joint" type="fixed">
    <parent link="base_link"/>
    <child link="sonar_back"/>
    <origin xyz="-0.2 0 0" rpy="0 0 3.14159"/> 
  </joint>
  <gazebo reference="sonar_back">
    <sensor type="ray" name="sonar_back_sensor">
      <pose>0 0 0 0 0 0</pose>
      <visualize>true</visualize>
      <update_rate>10</update_rate>
      <ray>
        <scan>
          <horizontal><samples>5</samples><resolution>1</resolution><min_angle>-0.26</min_angle><max_angle>0.26</max_angle></horizontal>
        </scan>
        <range><min>0.02</min><max>4.0</max><resolution>0.01</resolution></range>
      </ray>
      <plugin name="gazebo_ros_range_b" filename="libgazebo_ros_ray_sensor.so">
        <ros><remapping>~/out:=sonar/back</remapping></ros>
        <output_type>sensor_msgs/Range</output_type>
        <radiation_type>ultrasound</radiation_type>
        <frame_name>sonar_back</frame_name>
      </plugin>
    </sensor>
  </gazebo>

<gazebo>
    <plugin name="diff_drive" filename="libgazebo_ros_diff_drive.so">
      <update_rate>30</update_rate>

      <left_joint>left_wheel_joint</left_joint>
      <right_joint>right_wheel_joint</right_joint>

      <wheel_separation>0.4</wheel_separation> <wheel_diameter>0.2</wheel_diameter>   <max_wheel_torque>20</max_wheel_torque>
      <max_wheel_acceleration>1.0</max_wheel_acceleration>

      <command_topic>cmd_vel</command_topic>
      <publish_odom>true</publish_odom>
      <publish_odom_tf>true</publish_odom_tf>
      <publish_wheel_tf>true</publish_wheel_tf>
      <odometry_topic>odom</odometry_topic>
      <odometry_frame>odom</odometry_frame>
      <robot_base_frame>base_footprint</robot_base_frame>
    </plugin>

    <plugin name="joint_state_publisher" filename="libgazebo_ros_joint_state_publisher.so">
      <update_rate>30</update_rate>
      <joint_name>left_wheel_joint</joint_name>
      <joint_name>right_wheel_joint</joint_name>
    </plugin>
  </gazebo>

</robot>

