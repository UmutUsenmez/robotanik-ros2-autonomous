<?xml version="1.0"?>
<robot name="robotanik">
  <link name="base_footprint"/>

  <!-- BASE_FOOTPRINT: Dosya2'nin hesaplanan z offset'i (0.215) -->
  <joint name="base_footprint_joint" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link"/>
    <origin xyz="0 0 0.215" rpy="0 0 0"/>
    <!-- 0.215 = zemin + tekerlek yarıçapı(0.065) + gövde yarısı(0.15) -->
  </joint>

  <!-- BASE_LINK: 40cm x 30cm gövde (0.325 yükseklik) + Dosya2 fizik parametreleri -->
  <link name="base_link">
    <visual>
      <geometry>
        <box size="0.40 0.30 0.325"/>
      </geometry>
      <material name="green">
        <color rgba="0.0 0.8 0.0 1.0"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <box size="0.40 0.30 0.325"/>
      </geometry>
    </collision>
    <inertial>
      <!-- Dosya2'den: daha iyi navigasyon için optimize edilmiş inertia -->
      <mass value="15.0"/>
      <inertia ixx="0.284" ixy="0" ixz="0" iyy="0.542" iyz="0" izz="0.638"/>
    </inertial>
  </link>
  <gazebo reference="base_link">
    <material>Gazebo/Green</material>
  </gazebo>

  <!-- SAĞ TEKERLEK: Dosya1 link ismi + geometri + Dosya2 mu değerleri -->
  <link name="right_wheel">
    <visual>
      <geometry>
        <cylinder radius="0.065" length="0.058"/>
      </geometry>
      <material name="black">
        <color rgba="0.0 0.0 0.0 1.0"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.065" length="0.058"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.5"/>
      <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/>
    </inertial>
  </link>
  <gazebo reference="right_wheel">
    <material>Gazebo/Black</material>
    <!-- Dosya2'den: daha iyi tutuş için artırılmış mu -->
    <mu1>1.5</mu1>
    <mu2>1.5</mu2>
  </gazebo>

  <!-- Sağ tekerlek pozisyonu: 40x30cm gövdeye göre ayarlandı -->
  <joint name="right_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="right_wheel"/>
    <origin xyz="-0.135 -0.121 -0.1525" rpy="1.5708 0 0"/>
    <axis xyz="0 0 -1"/>
  </joint>

  <!-- SOL TEKERLEK: Dosya1 link ismi + geometri + Dosya2 mu değerleri -->
  <link name="left_wheel">
    <visual>
      <geometry>
        <cylinder radius="0.065" length="0.058"/>
      </geometry>
      <material name="black">
        <color rgba="0.0 0.0 0.0 1.0"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.065" length="0.058"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.5"/>
      <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/>
    </inertial>
  </link>
  <gazebo reference="left_wheel">
    <material>Gazebo/Black</material>
    <!-- Dosya2'den: daha iyi tutuş için artırılmış mu -->
    <mu1>1.5</mu1>
    <mu2>1.5</mu2>
  </gazebo>

  <!-- Sol tekerlek pozisyonu: 40x30cm gövdeye göre ayarlandı -->
  <joint name="left_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="left_wheel"/>
    <origin xyz="-0.135 0.121 -0.1525" rpy="-1.5708 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>

  <!-- SAĞ CASTER: Dosya1 link ismi + orijinal sphere geometrisi korundu -->
  <link name="right_caster_wheel">
    <visual>
      <geometry>
        <sphere radius="0.0275"/>
      </geometry>
      <material name="white">
        <color rgba="1.0 1.0 1.0 1.0"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <sphere radius="0.0275"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.2"/>
      <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/>
    </inertial>
  </link>
  <gazebo reference="right_caster_wheel">
    <material>Gazebo/White</material>
    <mu1>0.0</mu1>
    <mu2>0.0</mu2>
  </gazebo>

  <!-- Dosya1 joint ismi + orijinal pozisyon korundu -->
  <joint name="right_caster_joint" type="fixed">
    <parent link="base_link"/>
    <child link="right_caster_wheel"/>
    <origin xyz="0.15 -0.10 -0.19" rpy="0 0 0"/>
  </joint>

  <!-- SOL CASTER: Dosya1 link ismi + orijinal sphere geometrisi korundu -->
  <link name="left_caster_wheel">
    <visual>
      <geometry>
        <sphere radius="0.0275"/>
      </geometry>
      <material name="white">
        <color rgba="1.0 1.0 1.0 1.0"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <sphere radius="0.0275"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.2"/>
      <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/>
    </inertial>
  </link>
  <gazebo reference="left_caster_wheel">
    <material>Gazebo/White</material>
    <mu1>0.0</mu1>
    <mu2>0.0</mu2>
  </gazebo>

  <!-- Dosya1 joint ismi + orijinal pozisyon korundu -->
  <joint name="left_caster_joint" type="fixed">
    <parent link="base_link"/>
    <child link="left_caster_wheel"/>
    <origin xyz="0.15 0.10 -0.19" rpy="0 0 0"/>
  </joint>

  <!-- ===== SONAR SENSÖRLER =====
       Dosya1 link/joint isimleri + yatay pozisyonlar KORUNDU
       Dosya2'den: z=0.05 offset (sensörler gövde üst yarısında, daha iyi algılama) -->
  <link name="sonar_front_center">
    <visual>
      <geometry><box size="0.02 0.04 0.02"/></geometry>
      <material name="blue"><color rgba="0 0 1 1"/></material>
    </visual>
  </link>
  <joint name="sonar_front_center_joint" type="fixed">
    <parent link="base_link"/>
    <child link="sonar_front_center"/>
    <origin xyz="0.21 0 0.05" rpy="0 0 0"/>
  </joint>
  <gazebo reference="sonar_front_center">
    <material>Gazebo/Blue</material>
    <sensor type="ray" name="sonar_front_center_sensor">
      <pose>0 0 0 0 0 0</pose>
      <visualize>true</visualize>
      <update_rate>10</update_rate>
      <ray>
        <scan>
          <horizontal><samples>5</samples><resolution>1</resolution><min_angle>-0.26</min_angle><max_angle>0.26</max_angle></horizontal>
        </scan>
        <range><min>0.02</min><max>4.0</max><resolution>0.01</resolution></range>
      </ray>
      <plugin name="gazebo_ros_range_fc" filename="libgazebo_ros_ray_sensor.so">
        <ros><remapping>~/out:=sonar/front_center</remapping></ros>
        <output_type>sensor_msgs/Range</output_type>
        <radiation_type>ultrasound</radiation_type>
        <frame_name>sonar_front_center</frame_name>
      </plugin>
    </sensor>
  </gazebo>

  <link name="sonar_front_left">
    <visual>
      <geometry><box size="0.02 0.04 0.02"/></geometry>
      <material name="blue"><color rgba="0 0 1 1"/></material>
    </visual>
  </link>
  <joint name="sonar_front_left_joint" type="fixed">
    <parent link="base_link"/>
    <child link="sonar_front_left"/>
    <!-- Y=0.125 (kenara 2.5cm), açı=40° (0.698 rad) -->
    <origin xyz="0.21 0.125 0.05" rpy="0 0 0.698"/>
  </joint>
  <gazebo reference="sonar_front_left">
    <material>Gazebo/Blue</material>
    <sensor type="ray" name="sonar_front_left_sensor">
      <pose>0 0 0 0 0 0</pose>
      <visualize>true</visualize>
      <update_rate>10</update_rate>
      <ray>
        <scan>
          <horizontal><samples>5</samples><resolution>1</resolution><min_angle>-0.26</min_angle><max_angle>0.26</max_angle></horizontal>
        </scan>
        <range><min>0.02</min><max>4.0</max><resolution>0.01</resolution></range>
      </ray>
      <plugin name="gazebo_ros_range_fl" filename="libgazebo_ros_ray_sensor.so">
        <ros><remapping>~/out:=sonar/front_left</remapping></ros>
        <output_type>sensor_msgs/Range</output_type>
        <radiation_type>ultrasound</radiation_type>
        <frame_name>sonar_front_left</frame_name>
      </plugin>
    </sensor>
  </gazebo>

  <link name="sonar_front_right">
    <visual>
      <geometry><box size="0.02 0.04 0.02"/></geometry>
      <material name="blue"><color rgba="0 0 1 1"/></material>
    </visual>
  </link>
  <joint name="sonar_front_right_joint" type="fixed">
    <parent link="base_link"/>
    <child link="sonar_front_right"/>
    <!-- Y=-0.125 (kenara 2.5cm), açı=-40° (-0.698 rad) -->
    <origin xyz="0.21 -0.125 0.05" rpy="0 0 -0.698"/>
  </joint>
  <gazebo reference="sonar_front_right">
    <material>Gazebo/Blue</material>
    <sensor type="ray" name="sonar_front_right_sensor">
      <pose>0 0 0 0 0 0</pose>
      <visualize>true</visualize>
      <update_rate>10</update_rate>
      <ray>
        <scan>
          <horizontal><samples>5</samples><resolution>1</resolution><min_angle>-0.26</min_angle><max_angle>0.26</max_angle></horizontal>
        </scan>
        <range><min>0.02</min><max>4.0</max><resolution>0.01</resolution></range>
      </ray>
      <plugin name="gazebo_ros_range_fr" filename="libgazebo_ros_ray_sensor.so">
        <ros><remapping>~/out:=sonar/front_right</remapping></ros>
        <output_type>sensor_msgs/Range</output_type>
        <radiation_type>ultrasound</radiation_type>
        <frame_name>sonar_front_right</frame_name>
      </plugin>
    </sensor>
  </gazebo>

  <link name="sonar_back">
    <visual>
      <geometry><box size="0.02 0.04 0.02"/></geometry>
      <material name="blue"><color rgba="0 0 1 1"/></material>
    </visual>
  </link>
  <joint name="sonar_back_joint" type="fixed">
    <parent link="base_link"/>
    <child link="sonar_back"/>
    <!-- X=-0.21 (yeni robot uzunluğu 40cm) -->
    <origin xyz="-0.21 0 0.05" rpy="0 0 3.14159"/>
  </joint>
  <gazebo reference="sonar_back">
    <material>Gazebo/Blue</material>
    <sensor type="ray" name="sonar_back_sensor">
      <pose>0 0 0 0 0 0</pose>
      <visualize>true</visualize>
      <update_rate>10</update_rate>
      <ray>
        <scan>
          <horizontal><samples>5</samples><resolution>1</resolution><min_angle>-0.26</min_angle><max_angle>0.26</max_angle></horizontal>
        </scan>
        <range><min>0.02</min><max>4.0</max><resolution>0.01</resolution></range>
      </ray>
      <plugin name="gazebo_ros_range_b" filename="libgazebo_ros_ray_sensor.so">
        <ros><remapping>~/out:=sonar/back</remapping></ros>
        <output_type>sensor_msgs/Range</output_type>
        <radiation_type>ultrasound</radiation_type>
        <frame_name>sonar_back</frame_name>
      </plugin>
    </sensor>
  </gazebo>

  <!-- ===== DIFF DRIVE PLUGIN =====
       Dosya1 joint isimleri (left/right_wheel_joint) korundu
       wheel_separation: 30cm gövde genişliğine göre güncellendi (0.242) -->
  <gazebo>
    <plugin name="diff_drive" filename="libgazebo_ros_diff_drive.so">
      <update_rate>30</update_rate>
      <left_joint>left_wheel_joint</left_joint>
      <right_joint>right_wheel_joint</right_joint>
      <wheel_separation>0.242</wheel_separation>
      <wheel_diameter>0.130</wheel_diameter>
      <max_wheel_torque>20</max_wheel_torque>
      <max_wheel_acceleration>1.0</max_wheel_acceleration>
      <command_topic>cmd_vel</command_topic>
      <publish_odom>true</publish_odom>
      <publish_odom_tf>true</publish_odom_tf>
      <publish_wheel_tf>true</publish_wheel_tf>
      <odometry_topic>odom</odometry_topic>
      <odometry_frame>odom</odometry_frame>
      <robot_base_frame>base_footprint</robot_base_frame>
    </plugin>

    <plugin name="joint_state_publisher" filename="libgazebo_ros_joint_state_publisher.so">
      <update_rate>30</update_rate>
      <joint_name>left_wheel_joint</joint_name>
      <joint_name>right_wheel_joint</joint_name>
    </plugin>
  </gazebo>

</robot>
